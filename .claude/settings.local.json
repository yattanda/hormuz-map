{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git log*)",
      "Bash(git stash*)",
      "Bash(git checkout*)",
      "Bash(grep*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(wc*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(mkdir*)",
      "Bash(python*)",
      "Bash(node*)",
      "Bash(echo*)",
      "Bash(sed*)"
    ],
    "ask": ["Bash(git push*)"],
    "defaultMode": "acceptEdits"
  },
  "language": "japanese"
}
