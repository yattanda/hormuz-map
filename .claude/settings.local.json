{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git log*)",
      "Bash(git stash*)",
      "Bash(git checkout*)",
      "Bash(grep*)"
    ],
    "ask": [
      "Bash(git push*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "language": "japanese"
}
